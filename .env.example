# ── Required ──────────────────────────────────

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# OpenAI-compatible API key
OPENAI_API_KEY=

# ── Optional ──────────────────────────────────

# Custom API base URL (for OpenAI-compatible endpoints like together.ai, groq, vllm, etc.)
# Default: https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Model identifier
# Default: openai/gpt-5.4
MODEL_NAME=openai/gpt-5.4

# Memory embeddings provider
# Default: openai
# MEMORY_SEARCH_PROVIDER=openai

# Memory embeddings model
# Default: text-embedding-3-small
# MEMORY_SEARCH_MODEL=text-embedding-3-small

# Dedicated API base URL for memory embeddings
# Example: https://api.openai.com/v1
# MEMORY_SEARCH_API_BASE_URL=

# Dedicated API key for memory embeddings
# MEMORY_SEARCH_API_KEY=

# Force re-apply preset on container restart
# Default: false
FORCE_SETUP=false

# Gateway port
# Default: 18789
# OPENCLAW_GATEWAY_PORT=18789

# Heartbeat interval for proactive checks
# Example: 5m, 10m, 2m, 0m (disable)
# Default: preset value or 5m in container bootstrap when missing
# OPENCLAW_HEARTBEAT_EVERY=5m

# Heartbeat delivery target
# Example: last, telegram, discord, none
# Default: preset value or last in container bootstrap when missing
# OPENCLAW_HEARTBEAT_TARGET=last

# Prebuilt Docker image reference
# Default: ghcr.io/minpeter/oh-my-openclaw:latest
# OPENCLAW_IMAGE=ghcr.io/minpeter/oh-my-openclaw:latest
